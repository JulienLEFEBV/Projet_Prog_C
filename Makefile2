CC=gcc
CFLAGS=-std=c11 -Wpedantic -Wall -Wextra
RM=rm -f
OBJ=testgenea.o identite.o genea.o
EXE=testgenea
# Pour produire le fichier exécutable
$(EXE):$(OBJ)
	$(CC) $(CFLAGS) $(OBJ) -o $(EXE)
# Pour produire les fichiers objets
testgenea.o:testgenea.c genea.h
	$(CC) $(CFLAGS) -c testgenea.c
genea.o:genea.c genea.h identite.h
	$(CC) $(CFLAGS) -c genea.c
identite.o: identite.c identite.h
	$(CC) $(CFLAGS) -c identite.c
# Pour effacer les objets et les exécutables
clean:
	$(RM) $(OBJ) $(EXE)